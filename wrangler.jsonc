{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "campus-service-project",
  "main": "worker/index.ts",
  "compatibility_date": "2026-03-10",
  "compatibility_flags": [
    "nodejs_compat",
    "global_fetch_strictly_public"
  ],
  "assets": {
    "directory": "./public"
  },
  "observability": {
    "enabled": true
  },
  "upload_source_maps": true
}
